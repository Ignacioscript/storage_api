{
    "preset": "per",
    "rules": {
        "align_multiline_comment": true,
        "array_syntax": true,
        "declare_strict_types": true,
        "final_class": true,
        "strict_comparison": true,
        "ordered_imports": {
            "sort_algorithm": "alpha"
        },
        "no_unused_imports": true
    }
}
